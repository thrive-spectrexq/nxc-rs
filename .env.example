# NetExec-RS Strategy & Environment Configuration
# Copy this file to .env and replace placeholders with your actual keys

# --- 🤖 LLM Automation Service (Gemini) ---
# Required for /ai commands and autonomous mission control
# Obtain a key from https://aistudio.google.com/
GEMINI_API_KEY="your_gemini_api_key_here"
GEMINI_MODEL="gemini-2.5-flash"

# --- 🛰️ Telegram Protocol Integration ---
# Required for running the APEX-REAPER mission control bot
# Create a bot via @BotFather on Telegram
TELEGRAM_BOT_TOKEN="your_telegram_bot_token_here"

# List of authorized Telegram User IDs (comma-separated)
# Admin users have full control (e.g. /whitelist)
TELEGRAM_ADMIN_USERS="your_user_id_here"
# TELEGRAM_ALLOWED_USERS=""

# --- ⚙️ Networking & System ---
# Port for the health check server (useful for Render/Docker deployments)
PORT="10000"
