# NetExec-RS Strategy & Environment Configuration
# Copy this file to .env and replace placeholders with your actual keys

# --- 🤖 LLM Automation Service (Providers) ---
# Required for /ai commands and autonomous mission control
# The engine auto-detects which provider to use based on which key is populated.

# 1. Gemini (Default)
GEMINI_API_KEY=""
# GEMINI_MODEL="gemini-2.5-flash"

# 2. OpenAI
OPENAI_API_KEY=""
# OPENAI_MODEL="gpt-4o"

# 3. Anthropic (Claude)
ANTHROPIC_API_KEY=""
# ANTHROPIC_MODEL="claude-sonnet-4-20250514"

# 4. Ollama (Local)
OLLAMA_API_BASE=""
# OLLAMA_MODEL="llama3.2"



# --- ⚙️ Networking & System ---
# Port for the health check server (useful for Render/Docker deployments)
PORT="10000"
